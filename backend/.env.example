# Server
PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=vote_kit_dev

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-secret-key-change-in-production

# Coze AI Configuration
COZE_API_BASE=https://api.coze.cn
COZE_CLIENT_ID=your-coze-client-id
COZE_PUBLIC_KEY_ID=your-public-key-id
COZE_PRIVATE_KEY=your-private-key
COZE_BOT_ID=your-requirement-generation-bot-id
COZE_DEV_PLAN_BOT_ID=your-dev-plan-generation-bot-id

# Forge Engine Integration
VOTE_KIT_BASE_URL=http://localhost:3000
FORGE_REDIS_HOST=127.0.0.1
FORGE_REDIS_PORT=6380
FORGE_REDIS_PASSWORD=testpass
FORGE_EXPORT_SERVICE_URL=http://localhost:8081

# Credits 计费配置
# 基础：1 Credit = CREDIT_PRICE_CNY 元（含税），可按需调整
CREDIT_PRICE_CNY=0.01

# 单次调用预估最低 Credits（用于 checkQuota 预校验）
MIN_PROTO_CALL_CREDITS=1
MIN_CODE_CALL_CREDITS=10

# DeepSeek 价格（单位：元 / token）
DEEPSEEK_PRICE_PROMPT=0.000002      # 约等于 2 / 1_000_000
DEEPSEEK_PRICE_CACHE_HIT=0.0000005  # 约等于 0.5 / 1_000_000
DEEPSEEK_PRICE_COMPLETION=0.000008  # 约等于 8 / 1_000_000
DEEPSEEK_MARGIN=1.2                 # 毛利率系数，例如 1.2 = 加价 20%

# Kiro 价格与汇率
KIRO_PRICE_PER_CREDIT_USD=0.02      # 每个 kiro credit 的美元价格
USD_TO_CNY_RATE=6.87                # 美元兑人民币汇率
KIRO_MARGIN=1.45                    # 毛利率系数，例如 1.45 = 加价 45%

# 内测：新用户注册赠送 Credits（0=不赠送），以加油包形式一次性到账
WELCOME_CREDITS_BONUS=200
